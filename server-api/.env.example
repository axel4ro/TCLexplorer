NODE_ENV=production
PORT=4000
ADMIN_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=https://tclexplorer.com

DB_USER=tcl_app
DB_PASSWORD=replace-with-database-password
DB_NAME=tcl_db
DB_HOST=127.0.0.1
DB_PORT=5432

# Dedicated, unguarded MultiversX wallet used only for giveaway payouts.
# Keep the PEM outside the repository and restrict it to the API service account.
WHEEL_PAYOUT_PEM_PATH=/opt/tcl-api/secrets/wheel-payout.pem
MVX_CHAIN_ID=1
MVX_GATEWAY=https://gateway.multiversx.com
